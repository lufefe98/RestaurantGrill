<% layout('layouts/boilerplate') %>

  <div class="jumbotron">
    <h1>Gallery</h1>
    <hr class="hr-1">
  </div>


  <!-- IMAGE CAROUSELS -->


  <!-- Food Carousel -->
  <span class="carousel-heading">
    <h2>Food</h2>
  </span>

  <div class="jumbotron jumbotron-fluid gallery-carousel">
    <div class="container">

      <!-- carousel -->
      <div class="row">
        <div id="carouselExampleControls1" class="carousel slide mx-auto carousel-fade" data-bs-ride="carousel">
          <div class="carousel-inner">
            <div class="carousel-item active">
              <img
                src="https://media.istockphoto.com/photos/tastes-like-heaven-picture-id1295387335?b=1&k=20&m=1295387335&s=170667a&w=0&h=Q2VW1unCgv_n6AlUDD8u8yzWsn1kvVrH4iWqSEz4BPU="
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
            <div class="carousel-item">
              <img
                src="https://images.unsplash.com/photo-1600628421060-939639517883?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8NDB8fHNoYXJpbmclMjBwaXp6YXxlbnwwfHwwfHw%3D&auto=format&fit=crop&w=500&q=60"
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
            <div class="carousel-item">
              <img
                src="https://images.unsplash.com/photo-1600891964092-4316c288032e?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8Mnx8c3RlYWt8ZW58MHx8MHx8&auto=format&fit=crop&w=500&q=60"
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
          </div>
          <!-- carousel -->

          <!-- slide buttons -->
          <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls1"
            data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
          </button>
          <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls1"
            data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
          </button>
          <!-- slide buttons -->

        </div>
      </div>
    </div>
  </div>
  <!-- Food Carousel -->


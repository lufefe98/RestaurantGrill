<% layout('layouts/boilerplate') %>

  <div class="jumbotron">
    <h1>What's on the Menu?
    </h1>
    <hr class="hr-1">
  </div>

  <div class="jumbotron jumbotron-fluid">
    <div class="container">
      <div class="row">
        <div id="carouselExampleControls" class="carousel slide carousel-fade mx-auto" data-bs-ride="carousel">
          <div class="carousel-inner">
            <div class="carousel-item active">
              <img
                src="https://media.istockphoto.com/photos/delicious-meal-picture-id1295387240?b=1&k=20&m=1295387240&s=170667a&w=0&h=KtWYFjSBgpNgVkE3P-WKZ2F6V-VxyUBBtJIP_k8IANM="
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
            <div class="carousel-item">
              <img
                src="https://images.unsplash.com/photo-1414235077428-338989a2e8c0?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8M3x8cmVzdGF1cmFudHxlbnwwfHwwfHw%3D&auto=format&fit=crop&w=500&q=60"
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
            <div class="carousel-item">
              <img
                src="https://images.unsplash.com/photo-1574879948818-1cfda7aa5b1a?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8MjJ8fGJhcnxlbnwwfHwwfHw%3D&auto=format&fit=crop&w=500&q=60"
                class="d-block w-100 carousel-imgs" alt="...">
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="row d-flex flex-row">

      <!-- Drinks Menu -->
      <div class="card menu-card mx-auto col-sm-7 col-md-7 col-lg-3">
        <img
          src="https://images.unsplash.com/photo-1575037614876-c38a4d44f5b8?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8Mjh8fGJhcnxlbnwwfHwwfHw%3D&auto=format&fit=crop&w=500&q=60"
          class="card-img-top card-imgs" alt="...">

        <div class="card-body">
          <h5 class="card-title">Drinks Menu</h5>
          <p class="card-text" id="drinks-menu">
            Perfect for a get together with friends or for a solitary sundowner, we have something perfect for the
            occassion.
          </p>

          <div class="row align-items-center">
            <a href="#" class="btn btn-primary card-button">Our Drinks</a>
          </div>

        </div>

      </div>
      <!-- Drinks Menu -->

      <!-- Main Menu -->
      <div class="card menu-card mx-auto col-sm-7 col-md-7 col-lg-3">
        <img
          src="https://media.istockphoto.com/photos/restaurant-plates-picture-id104704117?b=1&k=20&m=104704117&s=170667a&w=0&h=ey87ESdQq9Gv0r_hmTuVLpF9H1hb0S3xcOBVOSWcZiw="
          class="card-img-top card-imgs" alt="...">

        <div class="card-body">
          <h5 class="card-title">Main Menu</h5>
          <p class="card-text menus-text">
            Feel free to take a look at our delicious and flavour filled starters, main meals and desserts.
          </p>

          <div class="row align-items-center">
            <a href="#" class="btn btn-primary card-button">Our Food</a>
          </div>

        </div>

      </div>
      <!-- Main Menu -->

      <!-- Specials Menu -->
      <div class="card menu-card mx-auto col-sm-7 col-md-7 col-lg-3">
        <img
          src="https://images.unsplash.com/photo-1519671282429-b44660ead0a7?ixlib=rb-1.2.1&ixid=MnwxMjA3fDB8MHxzZWFyY2h8MTh8fGZyaWVuZHMlMjBhdCUyMHJlc3RhdXJhbnR8ZW58MHx8MHx8&auto=format&fit=crop&w=500&q=60"
          class="card-img-top card-imgs" alt="...">

        <div class="card-body">
          <h5 class="card-title">Specials</h5>
          <p class="card-text menus-text">
            If you come at the right time, you can enjoy some of the specials we have on food and drinks.
          </p>

          <div class="row align-items-center">
            <a href="#" class="btn btn-primary card-button">Our Specials</a>
          </div>
        </div>

      </div>
      <!-- Specials Menu -->
    </div>
  </div>
